<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"   <!-- Xác định hướng sắp xếp là dọc -->
    android:padding="16dp"tools:context=".MainActivity">

<TextView android:id="@+id/textView1_linear" android:layout_width="wrap_content"
android:layout_height="wrap_content" android:text="Đây là TextView 1" android:textSize="20sp"
android:paddingBottom="8dp" />

<TextView android:id="@+id/textView2_linear" android:layout_width="wrap_content"
android:layout_height="wrap_content" android:text="Đây là TextView 2, nằm bên dưới TextView 1"
android:textSize="16sp" />

<Button android:id="@+id/button_linear" android:layout_width="wrap_content" android:layout_height="wrap_content"
android:layout_marginTop="16dp" android:text="Nút trong LinearLayout" />

    </LinearLayout><?xml version="1.0" encoding="utf-8"?><LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
